# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
env.local
# project standardizes on npm (package-lock.json); ignore bun's lockfile
# so a stray `bun install` doesn't drift the source of truth.
bun.lock
# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# sqlite data (local demo state)
/data/
*.db
*.db-wal
*.db-shm

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# bunq runtime state (installation token, server pub key, sub-account ids)
.bunq-context.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# forge: per-machine state stays local; shared artefacts (specs, plans, collab) commit.
/.forge/*
!/.forge/collab/
!/.forge/collab/**
!/.forge/specs/
!/.forge/specs/**
!/.forge/plans/
!/.forge/plans/**
